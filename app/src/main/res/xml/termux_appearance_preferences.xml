<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:title="@string/theme_title"
        app:iconSpaceReserved="false">

        <ListPreference
            app:key="theme_mode"
            app:title="@string/theme_mode_title"
            app:summary="@string/theme_mode_summary"
            app:entries="@array/theme_mode_entries"
            app:entryValues="@array/theme_mode_values"
            app:defaultValue="system"
            app:iconSpaceReserved="false" />

        <ListPreference
            app:key="locale_override"
            app:title="@string/locale_override_title"
            app:summary="@string/locale_override_summary"
            app:entries="@array/locale_override_entries"
            app:entryValues="@array/locale_override_values"
            app:defaultValue="system"
            app:iconSpaceReserved="false" />

        <CheckBoxPreference
            app:key="hide_extra_keys_with_keyboard"
            app:title="@string/hide_extra_keys_with_keyboard_title"
            app:summary="@string/hide_extra_keys_with_keyboard_summary"
            app:defaultValue="true"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="color_scheme_light"
            app:title="@string/color_scheme_light_title"
            app:summary="@string/color_scheme_light_summary"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="color_scheme_dark"
            app:title="@string/color_scheme_dark_title"
            app:summary="@string/color_scheme_dark_summary"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="@string/panel_transparency_title"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            app:key="button_bg_inactive_alpha"
            app:title="@string/termux_button_bg_inactive_alpha_title"
            app:defaultValue="5"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            app:key="button_bg_active_alpha"
            app:title="@string/termux_button_bg_active_alpha_title"
            app:defaultValue="12"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="@string/text_input_title"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            app:key="suggestions_max_count"
            app:title="@string/suggestions_max_count_title"
            app:summary="@string/suggestions_max_count_summary"
            app:defaultValue="4"
            android:max="10"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="shell_completion_enabled"
            app:title="@string/shell_completion_enabled_title"
            app:summary="@string/shell_completion_enabled_summary"
            app:defaultValue="false"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
