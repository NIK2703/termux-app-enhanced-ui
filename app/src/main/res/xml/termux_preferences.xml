<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <Preference
        app:title="@string/termux_debugging_preferences_title"
        app:summary="@string/termux_debugging_preferences_summary"
        app:fragment="com.termux.app.fragments.settings.termux.DebuggingPreferencesFragment"/>

    <Preference
        app:title="@string/termux_terminal_io_preferences_title"
        app:summary="@string/termux_terminal_io_preferences_summary"
        app:fragment="com.termux.app.fragments.settings.termux.TerminalIOPreferencesFragment"/>

    <Preference
        app:title="@string/termux_terminal_view_preferences_title"
        app:summary="@string/termux_terminal_view_preferences_summary"
        app:fragment="com.termux.app.fragments.settings.termux.TerminalViewPreferencesFragment"/>

    <PreferenceCategory app:title="@string/message_history_title" app:iconSpaceReserved="false">
        <SeekBarPreference
            app:key="message_history_max"
            app:title="@string/message_history_max_title"
            app:defaultValue="20"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="per_directory_message_history"
            app:title="@string/per_directory_message_history_title"
            app:summary="@string/per_directory_message_history_summary"
            app:defaultValue="false"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/text_input_title" app:iconSpaceReserved="false">
        <SwitchPreferenceCompat
            app:key="text_input_append_enter"
            app:title="@string/text_input_append_enter_title"
            app:summary="@string/text_input_append_enter_summary"
            app:defaultValue="true"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/directory_history_title" app:iconSpaceReserved="false">
        <SeekBarPreference
            app:key="directory_history_max"
            app:title="@string/directory_history_max_title"
            app:defaultValue="20"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            app:key="restore_sessions"
            app:title="@string/restore_sessions_title"
            app:summary="@string/restore_sessions_summary"
            app:defaultValue="true"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/screen_orientation_title" app:iconSpaceReserved="false">
        <ListPreference
            app:key="screen_orientation"
            app:title="@string/screen_orientation_title"
            app:summary="@string/screen_orientation_summary"
            app:entries="@array/screen_orientation_entries"
            app:entryValues="@array/screen_orientation_values"
            app:defaultValue="sensor"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/backup_restore_dialog_title" app:iconSpaceReserved="false">
        <Preference
            app:key="backup_container"
            app:title="@string/backup_preference_title"
            app:summary="@string/backup_preference_summary"
            app:iconSpaceReserved="false" />

        <Preference
            app:key="restore_container"
            app:title="@string/restore_preference_title"
            app:summary="@string/restore_preference_summary"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

</PreferenceScreen>
