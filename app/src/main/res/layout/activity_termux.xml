<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/activity_termux_root_relative_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="3dp"
        android:layout_marginVertical="0dp"
        android:orientation="vertical">

        <!-- Session tabs container (default: top). The applyTabPanelPosition()
             method moves this between ALIGN_PARENT_TOP and ABOVE the toolbar. -->
        <LinearLayout
            android:id="@+id/session_tabs_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/transparent"
            android:paddingVertical="2dp"
            android:layout_alignParentTop="true">

            <HorizontalScrollView
                android:id="@+id/session_tabs_scroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/session_tabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp">

                    <!-- Add tab button with + icon (scrolls with the tabs) -->
                    <ImageButton
                        android:id="@+id/new_session_tab_button"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_add"
                        android:background="@drawable/session_tab_background"
                        android:contentDescription="@string/action_new_session"
                        android:tint="@color/terminal_toolbar_icon_tint"
                        android:scaleType="center" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/terminal_view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/session_tabs_container"
            android:layout_above="@id/terminal_toolbar_container"
            android:orientation="horizontal" />

        <!-- Terminal toolbar: text input + extra keys. Always at the bottom. -->
        <LinearLayout
            android:id="@+id/terminal_toolbar_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/transparent"
            android:layout_alignParentBottom="true">

            <!-- Shared slot (FrameLayout) so the text input panel and the extra keys
                 overlap and can cross-fade their alpha instead of one abruptly
                 disappearing under the other. The extra keys is declared first (drawn
                 underneath) and pinned to the bottom; the input panel is declared last
                 (drawn on top, intercepting touches) so its text selection works while
                 the extra keys fades out beneath it. -->
            <FrameLayout
                android:id="@+id/terminal_toolbar_slot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.termux.shared.termux.extrakeys.ExtraKeysView
                    android:id="@+id/terminal_toolbar_extra_keys"
                    style="?android:attr/buttonBarStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@android:color/transparent"
                    android:orientation="horizontal" />

                <!-- Multi-line text input panel: occupies the slot below the tabs,
                     replacing the extra keys while active. Fixed height with vertical scroll. -->
                <FrameLayout
                    android:id="@+id/terminal_toolbar_text_input_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/text_input_transparent">

                    <com.termux.app.SendActionEditText
                        android:id="@+id/terminal_toolbar_text_input"
                        android:layout_width="match_parent"
                        android:layout_height="96dp"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginVertical="4dp"
                        android:imeOptions="actionSend|flagNoFullscreen"
                        android:inputType="textMultiLine"
                        android:maxLines="6"
                        android:scrollbars="vertical"
                        android:scrollHorizontally="false"
                        android:gravity="top|start"
                        android:importantForAutofill="no"
                        android:textSize="@dimen/text_input_text_size"
                        android:textColor="@color/terminal_toolbar_text_color"
                        android:textColorHighlight="@color/grey_400"
                        android:textCursorDrawable="@null"
                        android:background="@android:color/transparent"
                        tools:ignore="LabelFor" />

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Floating toggle text input visibility button (pencil).
             Floats over the terminal, bottom-right, vertically centered with the
             TerminalView scrollbar thumb when scrolled to the bottom.
             Always above the toolbar (which is always at the bottom). -->
        <ImageButton
            android:id="@+id/toggle_text_input_button"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_above="@id/terminal_toolbar_container"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="28dp"
            android:layout_marginBottom="6dp"
            android:visibility="visible"
            android:src="@drawable/ic_keyboard_show"
            android:background="@drawable/floating_button_background"
            android:contentDescription="@string/action_toggle_text_input"
            android:tint="@color/terminal_toolbar_icon_tint"
            android:scaleType="centerInside"
            android:padding="12dp" />

    </RelativeLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
