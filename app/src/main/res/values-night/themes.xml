<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Night-mode variant of TermuxActivity.Dialog.Button.
      MIUI/HyperOS system overlay can force button text to near-black even
      in dark mode; this explicit white keeps it readable on the dark dialog
      background.
    -->
    <style name="TermuxActivity.Dialog.Button" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
