<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
     https://material.io/develop/android/theming/dark
    -->

    <!-- TermuxApp Light DarkActionBar theme. -->
    <style name="Theme.TermuxApp.Light.DarkActionBar" parent="Theme.BaseActivity.Light.DarkActionBar"/>
    <!-- TermuxApp Light NoActionBar theme. -->
    <style name="Theme.TermuxApp.Light.NoActionBar" parent="Theme.BaseActivity.Light.NoActionBar"/>

    <!-- TermuxApp DayNight DarkActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.DarkActionBar" parent="Theme.BaseActivity.DayNight.DarkActionBar"/>
    <!-- TermuxApp DayNight NoActionBar theme. -->
    <style name="Theme.TermuxApp.DayNight.NoActionBar" parent="Theme.BaseActivity.DayNight.NoActionBar"/>

    <!-- Fully transparent theme for BackupDialogActivity: it hosts only the progress dialog and
         must not obscure (or replace) whatever screen is currently visible underneath. -->
    <style name="Theme.TermuxApp.Transparent" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>


    <!-- TermuxActivity DayNight NoActionBar theme. -->
    <!-- Light values: used when night mode is disabled, so the activity UI is light. -->
    <style name="Theme.TermuxActivity.DayNight.NoActionBar" parent="Theme.TermuxApp.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/grey_900</item>

        <item name="android:windowBackground">@color/white</item>

        <!-- Status bar: dark text/icons on light background -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Avoid action mode toolbar pushing down terminal content when
             selecting text on pre-6.0 (non-floating toolbar). -->
        <item name="android:windowActionModeOverlay">true</item>

        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>

        <!-- https://developer.android.com/training/tv/start/start.html#transition-color -->
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>

        <!-- Left drawer. -->
        <item name="buttonBarButtonStyle">@style/TermuxActivity.Drawer.ButtonBarStyle.Light</item>
        <item name="termuxActivityDrawerBackground">@color/scheme_dialog_background</item>
        <item name="termuxActivityDrawerImageTint">@color/scheme_dialog_foreground</item>

        <!-- Extra keys colors. -->
        <item name="extraKeysButtonTextColor">@color/black</item>
        <item name="extraKeysButtonActiveTextColor">@color/red_800</item>
        <item name="extraKeysButtonBackgroundColor">@color/extra_keys_button_background_light</item>
        <item name="extraKeysButtonActiveBackgroundColor">@color/extra_keys_button_active_background_light</item>
    </style>

    <!--
      Dialog theme overlay for TermuxActivity dialogs on MIUI/HyperOS.
      The system overlay can force dialog button text to near-black even in
      night mode; override materialAlertDialogButtonStyle with an explicit
      text colour that stays readable on a dark background.
    -->
    <style name="ThemeOverlay.TermuxActivity.Dialog" parent="ThemeOverlay.BaseDialog.DayNight">
        <item name="android:buttonBarButtonStyle">@style/TermuxActivity.Dialog.Button</item>
    </style>

    <style name="TermuxActivity.Dialog.Button" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <!-- Light-mode: black text on the light dialog background. -->
        <item name="android:textColor">@color/black</item>
    </style>

</resources>
