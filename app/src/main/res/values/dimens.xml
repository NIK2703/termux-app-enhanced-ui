<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Layout tolerance (px) for the bottom-panel margin / content-height logic.
         The available window rectangle reported by the system flickers by a few px every frame
         in small floating / freeform windows (the navigation bar / window decor appear and
         disappear, system insets jitter). That is sensor noise, not a real layout change, so we
         ignore any difference smaller than this band instead of recomputing and re-applying the
         bottom margin (or content height) on every frame, which previously caused an infinite
         set/reset oscillation that jittered the bottom panel. A real change — keyboard
         shown/hidden, window resized, split divider moved — moves the view by far more than this
         band and is still applied immediately. Must stay well below a keyboard height (~hundreds
         of px) so genuine changes are never swallowed. -->
    <dimen name="root_view_layout_tolerance">24dp</dimen>

    <!-- Tab dimensions -->
    <dimen name="terminal_tab_height_double">36dp</dimen>
    <dimen name="terminal_tab_height_single">24dp</dimen>
    <dimen name="terminal_tab_corner_radius">18dp</dimen>
    <dimen name="terminal_tab_padding_start_single">8dp</dimen>
    <dimen name="terminal_tab_padding_start_double">12dp</dimen>

    <!-- Text input panel (matches vertical scrollbar thumb) -->
    <dimen name="terminal_text_input_corner_radius">11dp</dimen>
    <dimen name="terminal_text_input_stroke">0.5dp</dimen>

    <!-- Auto-complete suggestions popup (message-history) -->
    <dimen name="autocomplete_popup_corner_radius">6dp</dimen>
    <dimen name="autocomplete_popup_elevation">8dp</dimen>
    <dimen name="autocomplete_popup_item_padding_horizontal">7dp</dimen>
    <dimen name="autocomplete_popup_item_padding_vertical">5dp</dimen>
    <dimen name="autocomplete_popup_min_width">200dp</dimen>
    <dimen name="autocomplete_popup_width_margin">16dp</dimen>
    <item name="autocomplete_popup_width_fraction" type="fraction">70%</item>
    <dimen name="autocomplete_popup_x_offset">4dp</dimen>
    <dimen name="autocomplete_popup_edge_margin">8dp</dimen>
    <dimen name="autocomplete_popup_y_offset">4dp</dimen>
    <dimen name="autocomplete_popup_min_y">16dp</dimen>
    <item name="autocomplete_popup_content_alpha" type="fraction">90%</item>
    <item name="autocomplete_popup_shadow_alpha" type="fraction">65%</item>

    <!-- Message history popup dimensions -->
    <dimen name="message_history_popup_max_height">520dp</dimen>
    <dimen name="message_history_popup_gap">24dp</dimen>
</resources>
