<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Terminal toolbar theme-aware colors (dark overrides) -->
    <color name="terminal_toolbar_background">#000000</color>
    <color name="terminal_toolbar_tabs_background">#000000</color>
    <color name="terminal_toolbar_text_color">#ffffff</color>
    <color name="terminal_toolbar_text_color_hint">#999999</color>
    <color name="terminal_toolbar_icon_tint">#ffffff</color>

    <!-- Drawable colors for dark mode, matching original hardcoded values -->
    <color name="terminal_toolbar_text_input_bg">#0a0a0a</color>
    <color name="terminal_toolbar_text_input_stroke">#333333</color>
    <color name="terminal_toolbar_session_tab_bg">#121212</color>
    <color name="terminal_toolbar_session_tab_bg_selected">#2a2a2a</color>
    <!-- Error text for finished-with-error session tabs; theme-aware so it stays
         readable on both light and dark tab backgrounds. -->
    <color name="terminal_tab_text_error">#FF6B6B</color>

    <!-- Extra keys / session tabs panel: text and active backgrounds. Same values as
         light so the signal panel (ESC/CTRL/...) stays visually identical in both themes. -->
    <color name="extra_keys_button_text">#ffffff</color>
    <color name="extra_keys_button_active_text">#80DEEA</color>
    <color name="extra_keys_button_active_background">#424242</color>

    <!-- Dark-mode overrides for the *_light variants referenced by
         Theme.TermuxActivity.DayNight.NoActionBar. Without these the night
         fallback would be the light gray from values/colors.xml. -->
    <color name="extra_keys_button_background_light">#121212</color>
    <color name="extra_keys_button_active_background_light">#2a2a2a</color>

    <!-- Settings screen/section header background in dark theme: 95% black + 5% white = #0D0D0D. -->
    <color name="settings_header_background">#0D0D0D</color>
</resources>
