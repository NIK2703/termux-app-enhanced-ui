<resources>
    <color name="background_markdown_code_inline">#1F000000</color>
    <color name="background_markdown_code_block">#0F000000</color>

    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <color name="red_400">#FF0000</color>
    <color name="red_800">#C4001D</color>

    <color name="grey_200">#EEEEEE</color>
    <color name="grey_400">#BDBDBD</color>
    <color name="grey_500">#9E9E9E</color>
    <color name="grey_800">#424242</color>
    <color name="grey_900">#212121</color>
    <color name="extra_keys_button_background">#1a1a1a</color>
    <color name="extra_keys_button_background_light">#e8e8e8</color>
    <color name="extra_keys_button_active_background_light">#cccccc</color>
    <!-- Extra keys / session tabs panel: text and active backgrounds, shared by both panels -->
    <color name="extra_keys_button_text">#ffffff</color>
    <color name="extra_keys_button_active_text">#80DEEA</color>
    <color name="extra_keys_button_active_background">#424242</color>

    <!-- Terminal toolbar theme-aware colors (light defaults) -->
    <color name="terminal_toolbar_background">#ffffff</color>
    <color name="terminal_toolbar_tabs_background">#f5f5f5</color>
    <color name="terminal_toolbar_text_color">#000000</color>
    <color name="terminal_toolbar_text_color_hint">#666666</color>
    <color name="terminal_toolbar_icon_tint">#000000</color>
    <color name="terminal_toolbar_text_input_bg">#f0f0f0</color>
    <color name="terminal_toolbar_text_input_stroke">#cccccc</color>
    <color name="terminal_toolbar_session_tab_bg">#e8e8e8</color>
    <color name="terminal_toolbar_session_tab_bg_selected">#d0d0d0</color>
    <!-- Error text for finished-with-error session tabs; theme-aware so it stays
         readable on both light and dark tab backgrounds. -->
    <color name="terminal_tab_text_error">#C4001D</color>

    <color name="red_error">#DC143C</color>
    <color name="red_error_link">#FC143C</color>

    <color name="blue_link_light">#0969DA</color>
    <color name="blue_link_dark">#58A6FF</color>

    <!-- Scheme-driven dialog colours. These are resolved at runtime (overridden by
         SchemeDialogTheme) to the active Termux:Style colour scheme, so dialogs are
         coloured correctly from the first frame without a post-show tint. -->
    <color name="scheme_dialog_background">#FF000000</color>
    <color name="scheme_dialog_surface">#FF000000</color>
    <color name="scheme_dialog_foreground">#FFFFFFFF</color>
    <color name="scheme_dialog_on_surface">#FFFFFFFF</color>
    <color name="scheme_dialog_divider">#80FFFFFF</color>
    <!-- Extra-keys / session-tab / floating-button backgrounds. Resolved at runtime to the
         scheme-derived translucent button colours (SchemeDialogTheme). -->
    <color name="scheme_dialog_button_background">#0D000000</color>
    <color name="scheme_dialog_button_active_background">#1F000000</color>
    <!-- Pressed/highlight selector for menu list rows: scheme foreground at ~25% alpha. -->
    <color name="scheme_dialog_selector">#40000000</color>
    <!-- Markdown code-block background: scheme foreground at ~8% alpha (visible on both
         light and dark schemes, replacing the old fixed black overlay). -->
    <color name="scheme_dialog_code_block">#14000000</color>
</resources>
